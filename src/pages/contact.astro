---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

// Web3Forms access key. Sign up at https://web3forms.com with the inbox you want
// submissions delivered to, then paste the key here. The key is safe to expose in
// client-side source - it only routes to your configured inbox and never reveals
// your email address. Enable domain restriction + hCaptcha in the Web3Forms
// dashboard to cut spam.
const WEB3FORMS_ACCESS_KEY = "5a358e29-cacc-4316-877f-8e15518a45cd";
---

<Layout
  title={`Contact | ${SITE.title}`}
  description="Send Daniel Miller a message."
>
  <Header />

  <main id="main-content" data-layout="contact" class="app-layout">
    <section class="mx-auto mb-16 mt-8 max-w-app">
      <h1 class="text-3xl font-bold sm:text-4xl">Contact</h1>
      <p class="mt-3 text-foreground/85">
        Have a project or a question? Send a message and it lands in my inbox.
      </p>

      <form
        id="contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        class="mt-8 flex flex-col gap-5 rounded-2xl bg-background-soft p-6 sm:p-8"
      >
        <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
        <input type="hidden" name="subject" value="New message from danielmiller.ca" />
        <input type="hidden" name="from_name" value="danielmiller.ca contact form" />
        <!-- honeypot: bots fill this, humans never see it -->
        <input
          type="checkbox"
          name="botcheck"
          class="hidden"
          style="display:none"
          tabindex="-1"
          autocomplete="off"
        />

        <div class="flex flex-col gap-2">
          <label for="name" class="font-medium">Name</label>
          <input
            id="name"
            type="text"
            name="name"
            required
            autocomplete="name"
            class="focus-outline rounded-lg border border-border bg-background px-3 py-2"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="email" class="font-medium">Email</label>
          <input
            id="email"
            type="email"
            name="email"
            required
            autocomplete="email"
            class="focus-outline rounded-lg border border-border bg-background px-3 py-2"
          />
        </div>

        <div class="flex flex-col gap-2">
          <label for="message" class="font-medium">Message</label>
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            class="focus-outline resize-y rounded-lg border border-border bg-background px-3 py-2"
          ></textarea>
        </div>

        <button
          type="submit"
          class="focus-outline w-fit rounded-lg bg-accent px-5 py-2 font-medium text-background transition-opacity hover:opacity-90"
        >
          Send message
        </button>

        <p
          id="form-status"
          role="status"
          aria-live="polite"
          class="hidden text-sm"
        >
        </p>
      </form>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const status = document.getElementById("form-status");
    if (!form || !status) return;

    const setStatus = (msg: string, ok: boolean) => {
      status.textContent = msg;
      status.classList.remove("hidden");
      status.classList.toggle("text-accent", ok);
      status.classList.toggle("text-red-500", !ok);
    };

    form.addEventListener("submit", async e => {
      e.preventDefault();
      const button = form.querySelector("button[type=submit]") as HTMLButtonElement;
      button.disabled = true;
      setStatus("Sending...", true);

      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" },
        });
        const data = await res.json();
        if (res.ok && data.success) {
          form.reset();
          setStatus("Thanks - your message has been sent. I'll be in touch.", true);
        } else {
          setStatus(data.message || "Something went wrong. Please try again.", false);
        }
      } catch {
        setStatus("Network error. Please try again.", false);
      } finally {
        button.disabled = false;
      }
    });
  });
</script>
